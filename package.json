{
  "name": "vite-react-node-ts",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test:client": "vitest --config client/vitest.config.ts",
    "test:server": "vitest --config server/vitest.config.ts",
    "client": "vite",
    "server": "tsx watch server/src/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc --project server/tsconfig.build.json",
    "start:server": "node dist/server/index.js",
    "build:client": "vite build",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:client": "eslint client --ext .ts,.tsx",
    "lint:server": "eslint server --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khatridev/vite-react-node-ts.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/khatridev/vite-react-node-ts/issues"
  },
  "homepage": "https://github.com/khatridev/vite-react-node-ts#readme",
  "dependencies": {
    "express": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/express": "^5.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitejs/plugin-react": "^4.1.0",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.1",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
